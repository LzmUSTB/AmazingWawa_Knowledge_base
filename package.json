{
  "name": "knowledge-system",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first knowledge graph system with desktop maintenance app and mobile viewer.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm run tauri dev -w apps/desktop",
    "dev:viewer": "npm run dev -w apps/viewer",
    "build:viewer": "npm run build -w apps/viewer",
    "kb:export-ai-context": "node packages/kinjito-protocol/scripts/export-ai-context.js",
    "kb:validate-ai-import": "node packages/kinjito-protocol/scripts/validate-ai-import.js",
    "kb:diff-ai-import": "node packages/kinjito-protocol/scripts/diff-ai-import.js",
    "kb:apply-ai-import": "node packages/kinjito-protocol/scripts/apply-ai-import.js",
    "kb:pack-ai-import": "node packages/kinjito-protocol/scripts/pack-ai-import.js",
    "kb:reset-fixture-vault": "node packages/kinjito-protocol/scripts/reset-fixture-vault.js",
    "kb:check-ai-import-mvp-b": "node packages/kinjito-protocol/scripts/check-ai-import-mvp-b.js",
    "lint": "echo \"lint is not configured yet\"",
    "check": "npm run check -w @kinjito/protocol && cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml"
  },
  "keywords": [
    "knowledge-base",
    "knowledge-graph",
    "tauri",
    "vue",
    "markdown",
    "yaml"
  ],
  "license": "MIT"
}
